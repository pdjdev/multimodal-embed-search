# Required: Gemini API key
GOOGLE_API_KEY=your_api_key_here

# Optional settings
CHUNK_LENGTH=32
EMBED_MODEL=gemini-embedding-2-preview
EMBED_DIM=768
SEARCH_TOP_K=5
# VLC_BIN=/usr/bin/vlc # use this if your host is linux/unix
DB_PATH=video_index.db
VIDEOS_DIR=videos
CHOPPED_DIR=chopped
VIDEO_EXTENSIONS=.mp4,.mov,.mkv,.webm

# FFmpeg settings
# FFMPEG_ENCODER=libopenh264 # use this if your host is linux or encoder not working
FFMPEG_PRESET=veryfast
FFMPEG_CRF=32
