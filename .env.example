# Required: Gemini API key
GOOGLE_API_KEY=your_api_key_here

# Optional settings
CHUNK_LENGTH=32
EMBED_MODEL=gemini-embedding-2-preview
EMBED_DIM=768
SEARCH_TOP_K=5
# Optional: absolute path to vlc executable (if not in PATH)
# VLC_BIN=C:/Program Files/VideoLAN/VLC/vlc.exe
DB_PATH=video_index.db
VIDEOS_DIR=videos
CHOPPED_DIR=chopped
VIDEO_EXTENSIONS=.mp4,.mov,.mkv,.webm
